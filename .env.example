# API
PORT=4000
NODE_ENV=production

# Security — REQUIRED in production
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_HEX

# CORS — comma-separated list of allowed frontend origins (production)
ALLOWED_ORIGINS=https://fms.yourdomain.com

# Database seeding
AUTO_SEED=true
SEED_XLSX_PATH=/app/seed-data/all-instruments-isg-2025.xlsx

# Logging: "json" for structured log aggregators (ELK, Splunk), omit for human-readable
# LOG_FORMAT=json

# PostgreSQL
DATABASE_URL=postgresql://fms:CHANGE_ME@db:5432/fms_track?schema=public

# Storage (MinIO/S3) — REPLACE default credentials in production
STORAGE_MODE=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=fms-track-docs
