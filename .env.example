# ─────────────────────────────────────────────────────────────────────────────
# ONGC FMS Track — Environment Variables
# Copy to .env and fill in all CHANGE_ME values before starting
# ─────────────────────────────────────────────────────────────────────────────

# ── API server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_HEX

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:4000

# ── Logging ───────────────────────────────────────────────────────────────────
# "json" for structured log aggregators (ELK, Splunk, Loki); omit for human-readable
LOG_FORMAT=json

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by Prisma directly (dev mode / migrations)
DATABASE_URL=postgresql://fms:CHANGE_ME@localhost:5432/fms_track?schema=public
# Component vars used by docker-compose to build DATABASE_URL internally
POSTGRES_DB=fms_track
POSTGRES_USER=fms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Database seeding ──────────────────────────────────────────────────────────
AUTO_SEED=true
SEED_XLSX_PATH=/app/seed-data/all-instruments-isg-2025.xlsx

# ── MinIO / S3 storage ────────────────────────────────────────────────────────
STORAGE_MODE=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
# In Docker, these map to MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
MINIO_ROOT_USER=CHANGE_ME_minio_access_key
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_secret_key
S3_BUCKET=fms-track-docs

# ── Application ────────────────────────────────────────────────────────────────
# Host port that maps to nginx (docker-compose web service)
APP_PORT=4000
